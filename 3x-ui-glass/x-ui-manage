fire_animation() {
    local frames=(
        "                 🔥💨                    💨🔥"
        "              🔥🔥💨                  💨🔥🔥"
        "           🔥💥✨                        ✨💥🔥"
        "        ✨  ·  ·                            ·  ·  ✨"
        "                                                    "
    )
    for frame in "${frames[@]}"; do
        echo -e "${RED}${frame}${PLAIN}"
        sleep 0.15
    done
}

confirm() {
    local msg="${1:-Are you sure?}"
    echo -e "${YELLOW}⚠️  ${msg} (y/n): ${PLAIN}\c"
    read -r ans
    [[ "$ans" == "y" || "$ans" == "Y" ]]
}

ask_restart() {
    echo -e ""
    echo -e "${CYAN}🔄 Restart x-ui and xray now? (y/n): ${PLAIN}\c"
    read -r ans
    if [[ "$ans" == "y" || "$ans" == "Y" ]]; then
        systemctl restart x-ui
        echo -e "${GREEN}✅ x-ui restarted.${PLAIN}"
    fi
}

check_status() {
    if systemctl is-active --quiet x-ui 2>/dev/null; then
        PANEL_STATE="${GREEN}Running${PLAIN}"
    else
        PANEL_STATE="${RED}Stopped${PLAIN}"
    fi

    if systemctl is-enabled --quiet x-ui 2>/dev/null; then
        AUTO_START="${GREEN}Yes${PLAIN}"
    else
        AUTO_START="${RED}No${PLAIN}"
    fi

    if pgrep -x "xray" > /dev/null 2>&1 || pgrep -f "xray-linux" > /dev/null 2>&1; then
        XRAY_STATE="${GREEN}Running${PLAIN}"
    else
        XRAY_STATE="${RED}Stopped${PLAIN}"
    fi
}

